# Firebase client config — safe to expose publicly (research.md: this is
# the client-side apiKey, protected by Firestore rules, not by secrecy).
# Still point this at the SAME demo-dedicated Firebase project as
# apps/server/.env, never the original motionbit-kpopschool project.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Defaults to "/api" (see vite.config.ts dev proxy -> localhost:8090).
# Set to the deployed server's URL in production.
VITE_API_BASE_URL=

# Set to "true" for local dev/demo against the Firebase Local Emulator Suite
# (see apps/server/.env.example) instead of a real Firebase project.
VITE_USE_FIREBASE_EMULATOR=false
VITE_FIREBASE_AUTH_EMULATOR_URL=http://127.0.0.1:19099
