# Copy to .env and fill in with your OWN demo-only Firebase project + test-mode
# Stripe/Zoom credentials. Never commit the real .env file (see ../../.gitignore).

PORT=8080

# "demo" (default): Stripe/Zoom calls are mocked, Firestore is still real.
# "real": actual Stripe (test mode) + Zoom SDK calls are made. Never set this
# to "real" on the public demo deployment (NFR-003).
INTEGRATION_MODE=demo

# Firebase Admin SDK — create a NEW Firebase project dedicated to this demo,
# never reuse a production project. Firestore is always exercised for real,
# in both demo and real INTEGRATION_MODE.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Local dev/demo alternative to a real project: run `pnpm run emulators` at
# the repo root (Firebase Local Emulator Suite), then set these two so
# firebase-admin talks to the emulator instead of real GCP. Only
# FIREBASE_PROJECT_ID is read in that mode (set it to anything, e.g.
# "kpopschool-demo-local") — CLIENT_EMAIL/PRIVATE_KEY are ignored.
# Ports are deliberately non-default (firebase.json) — the standard
# 9099/8080/4000 collide with any other Firebase emulator you might have
# running for an unrelated project on the same machine.
FIRESTORE_EMULATOR_HOST=127.0.0.1:18085
FIREBASE_AUTH_EMULATOR_HOST=127.0.0.1:19099

# Only required when INTEGRATION_MODE=real. Use TEST MODE keys only.
STRIPE_SECRET_KEY=

# Only required when INTEGRATION_MODE=real.
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
ZOOM_ACCOUNT_ID=
ZOOM_SDK_KEY=
ZOOM_SDK_SECRET=

# Seeded demo visitor account (FR-010). Password is never used for sign-in
# (custom-token flow only) but must still be set for Firebase Auth creation.
DEMO_ACCOUNT_EMAIL=demo@kpopschool.portfolio
DEMO_ACCOUNT_PASSWORD=
