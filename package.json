    "seed": "pnpm --filter server run seed",
    "emulators": "firebase emulators:start --project kpopschool-demo-local"
  },
  "devDependencies": {
    "firebase-tools": "^15.0.0",
    "turbo": "^2.3.0",
    "typescript": "^5.6.0"
  }
}
